#version 460

/// Floating point epsilon, rounded up
const float EPSILON = 1e-6;
const double PI = 3.141592653589793lf;
const double PHI = PI * (sqrt(5.0lf) - 1.0lf);
/// Well defined behavior that results in inf
const float INFINITY = 1.0 / 0.0;

layout (constant_id = 0) const uint width = 1;
layout (constant_id = 1) const uint height = 1;
layout (constant_id = 2) const uint indexCount = 3;
layout (constant_id = 3) const uint dispatchCount = 1;

struct MapVertex {
    vec3 position;
    vec2 uv;
    vec2 lightmapUv;
    vec3 normal;
};

const MapVertex mapVertexZero = MapVertex(vec3(0), vec2(0), vec2(0), vec3(0));

struct MapTriangle {
    MapVertex a;
    MapVertex b;
    MapVertex c;
};

const MapTriangle mapTriangleZero = MapTriangle(mapVertexZero, mapVertexZero, mapVertexZero);

struct Intersection {
    float distance;
    vec3 intersection;
    MapTriangle triangle;
    bool isBackface;
    float lightStrength;
};

const Intersection intersectionNone = Intersection(INFINITY, vec3(0), mapTriangleZero, false, 0);

layout (std140, set = 0, binding = 0) readonly buffer VertexData {
    MapVertex vertices[];
} vertexData;

layout (set = 0, binding = 1) readonly buffer IndexData {
    uint indices[];
} indexData;

/// A pair of buffers used for keping track of which luxels have been hit by a ray on the previous pass and this pass
layout (set = 0, binding = 2) buffer LuxelIndicesData {
    /// A list of luxel indices of length `count`
    int indices[width * height];
} luxelIndicesData[2];

/// A buffer containing the hit count of every luxel
/// Having this both allows for keeping track of the number of hits, as well as easy lookup to see if a luxel has already been counted
layout (set = 0, binding = 3) buffer HitIndicesData {
    /// The total number of luxels that have been hit thus far, not counting duplicates
    uint count;
    uint indices[width * height / 4];
} hitIndicesData;

layout (set = 0, binding = 4) buffer LightHitIndicesData {
    uint indices[]; // width * height * gl_NumWorkGroups.z / 32
} lightHitIndicesData;

layout (set = 0, binding = 5) buffer LightmapLuxels {
    uint luxels[width * height * 3];
} lightmap;

layout (local_size_x = 16, local_size_y = 16, local_size_z = 1) in;
layout (local_size_x_id = 4) in;
layout (local_size_y_id = 5) in;

// Thanks to https://web.archive.org/web/20250919062256if_/https://www.graphics.cornell.edu/pubs/1997/MT97.pdf
//  which this code is based on
Intersection calculateIntersection(vec3 origin, vec3 ray, MapTriangle triangle) {
    vec3 edge1 = triangle.b.position - triangle.a.position;
    vec3 edge2 = triangle.c.position - triangle.a.position;

    vec3 pvec = cross(ray, edge2);

    float det = dot(edge1, pvec);
    if (abs(det) < EPSILON) {
        return intersectionNone;
    }

    float inverse_det = 1.0 / det;

    vec3 tvec = origin - triangle.a.position;

    float u = dot(tvec, pvec) * inverse_det;
    if (u < -EPSILON || u - 1 > EPSILON) {
        return intersectionNone;
    }

    vec3 qvec = cross(tvec, edge1);

    float v = dot(ray, qvec) * inverse_det;
    if (v < -EPSILON || u + v - 1 > EPSILON) {
        return intersectionNone;
    }

    float distance = dot(edge2, qvec) * inverse_det;
    if (distance > EPSILON) {
        return Intersection(distance, origin + ray * distance, triangle, det < EPSILON, 0);
    } else {
        return intersectionNone;
    }
}

vec2 computeLuxelUv(MapTriangle triangle, vec3 hit) {
    vec3 v0 = triangle.b.position - triangle.a.position;
    vec3 v1 = triangle.c.position - triangle.a.position;
    vec3 v2 = hit - triangle.a.position;

    float d00 = dot(v0, v0);
    float d01 = dot(v0, v1);
    float d11 = dot(v1, v1);
    float d20 = dot(v2, v0);
    float d21 = dot(v2, v1);
    float denom = d00 * d11 - d01 * d01;

    float b = (d11 * d20 - d01 * d21) / denom;
    float c = (d00 * d21 - d01 * d20) / denom;
    float a = 1.0 - b - c;

    return a * triangle.a.lightmapUv + b * triangle.b.lightmapUv + c * triangle.c.lightmapUv;
}
int computeLuxelIndex(MapTriangle triangle, vec3 hit) {
    vec2 uv = computeLuxelUv(triangle, hit);
    return int(int(uv.x * width) + int(uv.y * height) * width);
}

