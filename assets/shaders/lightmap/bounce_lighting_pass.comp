/**
 * Add one to the hit counter of a given luxel index
 * @param index The index of the luxel
 * @return True if the luxel had not previously been hit
 */
bool atomicHitIndex(int index) {
    // This function mandates (but does not enforce) a limit of 255 lights hitting the same luxel
    const uint shift = (8 * (index % 4));
    return (atomicAdd(hitIndicesData.indices[index / 4], 1 << shift) & (0xFF << shift)) == 0;
}

vec3 getRay(uint index) {
    const double maxSample = double(gl_WorkGroupSize.x * gl_NumWorkGroups.x * gl_WorkGroupSize.y * gl_NumWorkGroups.y * dispatchCount);
    double y = 1 - (index / maxSample) * 2;

    double radius = sqrt(1 - y * y);
    float theta = float(mod(PHI * index, 2 * PI) - PI);

    return vec3(float(cos(theta) * radius), float(y), float(sin(theta) * radius));
}

void atomicAddColorToLuxelChannel(int luxel, int channel, float val) {
    // atomicExchange(lightmap.luxels[luxel + channel], floatBitsToUint(val));
    atomicCompSwap(lightmap.luxels[luxel + channel], 0, floatBitsToUint(val));
    // float val1 = uintBitsToFloat(lightmap.luxels[luxel + channel]);
    // float val2 = uintBitsToFloat(lightmap.luxels[luxel + channel]);
    // do {
    //     val1 = val2;
    //     val2 = uintBitsToFloat(atomicCompSwap(lightmap.luxels[luxel + channel], floatBitsToUint(val1), floatBitsToUint(val1 + val)));
    // } while (val1 != val2);
}
void atomicAddColorToLightmap(vec3 color, int index) {
    atomicAddColorToLuxelChannel(3 * index, 0, color.r);
    atomicAddColorToLuxelChannel(3 * index, 1, color.g);
    atomicAddColorToLuxelChannel(3 * index, 2, color.b);
}

bool atomicLightHitLuxelIndex(uint luxelIndex) {
    const uint index = luxelIndex * gl_NumWorkGroups.z + gl_WorkGroupID.z;
    const uint bit = 1 << (index % 32);
    return (atomicOr(lightHitIndicesData.indices[index / 32], bit) & bit) == 0;
}

struct Funny {
    vec3 pos;
    MapTriangle triangle;
};

Funny findPositionOfLuxel(int luxelIndex) {
    vec2 uv = vec2(float(luxelIndex) / width / height, float(luxelIndex % width) / width);
    for (uint i = 0; i + 2 < indexCount; i += 3) {
        MapTriangle triangle = MapTriangle(vertexData.vertices[indexData.indices[i]],
                                           vertexData.vertices[indexData.indices[i + 1]],
                                           vertexData.vertices[indexData.indices[i + 2]]);
        vec2 v0 = triangle.b.lightmapUv - triangle.a.lightmapUv;
        vec2 v1 = triangle.c.lightmapUv - triangle.a.lightmapUv;
        vec2 v2 = uv - triangle.a.lightmapUv;

        float d00 = dot(v0, v0);
        float d01 = dot(v0, v1);
        float d11 = dot(v1, v1);
        float d20 = dot(v2, v0);
        float d21 = dot(v2, v1);
        float denom = d00 * d11 - d01 * d01;

        float b = (d11 * d20 - d01 * d21) / denom;
        float c = (d00 * d21 - d01 * d20) / denom;

        float a = 1.0 - b - c;
        return Funny(a * triangle.a.position + b * triangle.b.position + c * triangle.c.position, triangle);
        // if (b > -EPSILON && c > -EPSILON) {
        //     float a = 1.0 - b - c;
        //     if (a > -EPSILON) {
        //         return a * triangle.a.position + b * triangle.b.position + c * triangle.c.position;
        //     }
        // }
    }
    return Funny(vec3(INFINITY), mapTriangleZero);
}

vec3 getLightmapLuxelColor(int index) {
    return vec3(uintBitsToFloat(lightmap.luxels[3 * index]),
                uintBitsToFloat(lightmap.luxels[3 * index + 1]),
                uintBitsToFloat(lightmap.luxels[3 * index + 2]));
}

